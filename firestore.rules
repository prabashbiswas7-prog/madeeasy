rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and update only their own profile document.
    // Account creation writes this document right after signup.
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Bookings can only be created by a signed-in user for themselves,
    // and only read back by the user who made them.
    match /bookings/{bookingId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow update, delete: if false;
    }
  }
}
