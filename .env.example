# Firebase project config — get these from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# WhatsApp number that receives bookings, country code + number, no + or spaces
# Example: 91XXXXXXXXXX
VITE_WHATSAPP_NUMBER=

# Brand contact info shown on Contact page
VITE_SUPPORT_EMAIL=hello@madeeasy.in
VITE_SUPPORT_PHONE=+91 00000 00000
